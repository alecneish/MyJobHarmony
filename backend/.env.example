# Backend environment

# Connection string to dev Supabase/Postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase REST (needed for backend reads/writes) (in the APIs box after running `supabase start`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SECRET_KEY= # use the Secret key from `supabase start`
# Optional: publishable key if you need it for client contexts
SUPABASE_PUBLISHABLE_KEY=

# Optional: override API port
# PORT=3001
