# All backend secrets live in backend/.env (not the repo root). The root .env is only for
# Docker Compose VITE_* frontend build args when deploying.

# ── Local development — keep pointing at local Supabase (`npx supabase start`) ─────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
# Dashboard → Project Settings → API → service_role (secret). Code reads SUPABASE_SECRET_KEY.
SUPABASE_SECRET_KEY=<service_role key from `npx supabase start` output>

# ── CORS — comma-separated origins allowed by the Express API ─────────────────────────
# Not needed when nginx proxies /api (same origin), but useful for direct access or alt deploys.
# CORS_ORIGIN=http://localhost:5173,https://job-harmony.information-systems.net

# ── Production — hosted Supabase (same project as the frontend anon key) ──────────────
# Host: db.zcwthrvshszrdewkrnll.supabase.co  Port: 5432  Database: postgres  User: postgres
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.zcwthrvshszrdewkrnll.supabase.co:5432/postgres
# SUPABASE_URL=https://zcwthrvshszrdewkrnll.supabase.co
# SUPABASE_SECRET_KEY=<production service_role secret from Supabase dashboard>
