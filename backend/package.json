{
  "name": "jobharmony-backend",
  "version": "1.0.0",
  "description": "JobHarmony Node.js/Express/TypeScript backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node -r dotenv/config node_modules/ts-node-dev/bin/ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate -j 1 -d $DATABASE_URL -m migrations",
    "migrate:create": "node-pg-migrate create -m migrations"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.17",
    "node-pg-migrate": "^8.0.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
