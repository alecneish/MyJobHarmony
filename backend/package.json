{
  "name": "jobharmony-backend",
  "version": "1.0.0",
  "description": "JobHarmony Node.js/Express/TypeScript backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "supabase db push",
    "migrate:reset": "supabase db reset",
    "migrate:create": "supabase migration new"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.17",
    "node-pg-migrate": "^8.0.4",
    "supabase": "^2.78.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
