# JobHarmony — Environment Configuration Reference
#
# This app uses ASP.NET Core configuration. There are two ways to set these values:
#
# Option A (recommended for development): edit appsettings.Development.json
# Option B: set environment variables using the __ separator for nested keys
#
# Example environment variable format:
#   ConnectionStrings__DefaultConnection=Data Source=jobharmony.db
#   ASPNETCORE_ENVIRONMENT=Development

# -----------------------------------------------------------------
# Database
# -----------------------------------------------------------------
# SQLite (default — no server required)
ConnectionStrings__DefaultConnection=Data Source=jobharmony.db

# -----------------------------------------------------------------
# ASP.NET Core
# -----------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# -----------------------------------------------------------------
# Future: Auth / External APIs (not yet implemented)
# -----------------------------------------------------------------
# JWT__Secret=your_jwt_secret_here
# JWT__Issuer=https://localhost:5000
# JWT__Audience=https://localhost:5000
