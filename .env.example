# Docker Compose loads `.env` (same folder as docker-compose.yml) for variable substitution;
# those values are passed as build args so Vite embeds Supabase settings into the frontend bundle.
#
# Do not put DATABASE_URL or server-side Supabase keys here — those belong in backend/.env only.
#
# deploy.sh excludes normal `.env` files from rsync. Easiest: copy this file to `jobharmony.env`
# in the repo root, fill in values, and run deploy — the script uploads `jobharmony.env` to the
# server as `.env`. Or create `.env` manually on the server from this template.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: only if you use this name instead of VITE_SUPABASE_PUBLISHABLE_KEY
# VITE_SUPABASE_ANON_KEY=
