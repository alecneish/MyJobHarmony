@model JobHarmony.Models.JobListingsViewModel

<aside class="jh-filter-sidebar" id="jh-filter-panel">
    <div class="jh-filter-sidebar-header">
        <h4>Filters</h4>
        <button class="jh-filter-sidebar-close" id="jh-filter-close">&times;</button>
    </div>

    <div class="jh-filter-sidebar-body">
        <div class="jh-filter-row">
            <h5 class="jh-filter-row-title">Type</h5>
            <div class="jh-filter-row-options">
                @foreach (var type in Model.AllTypes)
                {
                    <label class="jh-filter-label">
                        <input type="checkbox" class="jh-filter-checkbox" data-filter="type" value="@type" />
                        <span>@type</span>
                    </label>
                }
            </div>
        </div>

        <div class="jh-filter-row">
            <h5 class="jh-filter-row-title">Location</h5>
            <div class="jh-filter-row-options">
                @foreach (var loc in Model.AllLocations)
                {
                    <label class="jh-filter-label">
                        <input type="checkbox" class="jh-filter-checkbox" data-filter="location" value="@loc" />
                        <span>@loc</span>
                    </label>
                }
            </div>
        </div>

        <div class="jh-filter-row">
            <h5 class="jh-filter-row-title">Tags</h5>
            <div class="jh-filter-row-options">
                @foreach (var tag in Model.AllTags)
                {
                    <label class="jh-filter-label">
                        <input type="checkbox" class="jh-filter-checkbox" data-filter="tags" value="@tag" />
                        <span>@tag</span>
                    </label>
                }
            </div>
        </div>
    </div>

    <div class="jh-filter-sidebar-footer">
        <button class="jh-btn-secondary" id="jh-filter-clear">Clear All</button>
        <button class="jh-btn-primary" id="jh-filter-apply">Apply</button>
    </div>
</aside>
