@model JobHarmony.Models.Applicant

<div class="jh-applicant-card">
    <div class="jh-applicant-header">
        <div class="jh-avatar" style="background-color: @Model.AvatarColor;">@Model.Initials</div>
        <div>
            <div class="jh-applicant-name">
                @Model.Name
                @if (Model.IsRecommended)
                {
                    <span class="jh-recommended-badge">Recommended</span>
                }
            </div>
            <div class="jh-applicant-title">@Model.Title</div>
        </div>
    </div>

    <div class="jh-applicant-skills">
        @foreach (var skill in Model.Skills)
        {
            <span class="jh-skill-tag">@skill</span>
        }
    </div>

    <div class="jh-fit-badges">
        <div class="jh-circular-badge">
            <div class="jh-circular-badge-ring resume">@Model.ResumeFitPercent%</div>
            <span class="jh-circular-badge-label">Resume</span>
        </div>
        <div class="jh-circular-badge">
            <div class="jh-circular-badge-ring personality">@Model.PersonalityFitPercent%</div>
            <span class="jh-circular-badge-label">Personality</span>
        </div>
    </div>
</div>
