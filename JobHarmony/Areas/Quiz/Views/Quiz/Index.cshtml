@model JobHarmony.Areas.Quiz.ViewModels.QuizStartViewModel
@{
    ViewData["Title"] = "Career Quiz";
}

<section class="hero-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h1 class="display-4 fw-bold mb-3">Discover Your Ideal Career</h1>
                <p class="lead text-muted mb-5">
                    A science-backed assessment that matches your personality, interests, values,
                    and work style to careers where you'll actually thrive.
                </p>
            </div>
        </div>

        <div class="row justify-content-center g-4">
            <div class="col-md-5">
                <div class="card tier-card h-100">
                    <div class="card-body text-center p-4">
                        <span class="badge bg-primary-subtle text-primary mb-3">Free</span>
                        <h3 class="fw-bold">Core Assessment</h3>
                        <p class="text-muted mb-4">
                            Get a clear picture of your personality, interests, and top career matches.
                        </p>
                        <ul class="list-unstyled text-start tier-features mb-4">
                            <li>@Model.FreeQuestionCount research-backed questions</li>
                            <li>Big Five personality profile</li>
                            <li>Holland Code career interests</li>
                            <li>Work values assessment</li>
                            <li>Top 10 career matches</li>
                        </ul>
                        <div class="text-muted small mb-3">~@Model.FreeEstimatedMinutes minutes</div>
                        <form asp-action="Start" method="post">
                            <input type="hidden" name="tier" value="Free" />
                            <button type="submit" class="btn btn-primary btn-lg w-100">Start Free Quiz</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card tier-card tier-card-premium h-100">
                    <div class="card-body text-center p-4">
                        <span class="badge bg-warning text-dark mb-3">Premium</span>
                        <h3 class="fw-bold">Deep Insight Assessment</h3>
                        <p class="text-muted mb-4">
                            Everything in Free, plus deeper analysis, stress patterns, and psychological needs.
                        </p>
                        <ul class="list-unstyled text-start tier-features mb-4">
                            <li>@Model.PremiumQuestionCount comprehensive questions</li>
                            <li>30-facet personality deep dive</li>
                            <li>Stress behavior analysis</li>
                            <li>Psychological needs profile</li>
                            <li>Career stage &amp; grit assessment</li>
                            <li>Top 15 career matches with insights</li>
                        </ul>
                        <div class="text-muted small mb-3">~@Model.PremiumEstimatedMinutes minutes</div>
                        <form asp-action="Start" method="post">
                            <input type="hidden" name="tier" value="Premium" />
                            <button type="submit" class="btn btn-warning btn-lg w-100 fw-semibold">Start Premium Quiz</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="row justify-content-center mt-5">
            <div class="col-lg-8">
                <div class="row g-4 text-center">
                    <div class="col-md-4">
                        <div class="methodology-item">
                            <div class="methodology-icon">&#x1F9E0;</div>
                            <h6 class="fw-bold">Science-Backed</h6>
                            <small class="text-muted">Built on Big Five, Holland Codes, and Self-Determination Theory</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="methodology-item">
                            <div class="methodology-icon">&#x1F3AF;</div>
                            <h6 class="fw-bold">Career Matching</h6>
                            <small class="text-muted">Matched against 60+ career profiles using multi-dimensional analysis</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="methodology-item">
                            <div class="methodology-icon">&#x1F512;</div>
                            <h6 class="fw-bold">No Account Needed</h6>
                            <small class="text-muted">Take the quiz instantly. Your answers stay private.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
