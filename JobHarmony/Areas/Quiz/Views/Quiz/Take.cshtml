@model JobHarmony.Areas.Quiz.ViewModels.QuizPageViewModel
@{
    ViewData["Title"] = "Take the Quiz";
}

<div class="quiz-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <!-- Progress Bar -->
                <div class="quiz-progress mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="text-muted fw-semibold section-label"></small>
                        <small class="text-muted">
                            <span id="answeredCount">@Model.AnsweredQuestions</span> / @Model.TotalQuestions
                        </small>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar" role="progressbar"
                             style="width: @((Model.AnsweredQuestions * 100 / Math.Max(1, Model.TotalQuestions)))%"></div>
                    </div>
                </div>

                <!-- Questions rendered per section -->
                @{ int globalIndex = 0; }
                @foreach (var section in Model.Sections)
                {
                    foreach (var q in section.Questions)
                    {
                        <div class="question-card" data-index="@globalIndex" data-section="@(section.SectionName)"
                             data-question-id="@q.Id" data-format="@q.QuestionFormat" style="display:none;">

                            <div class="sec-header mb-2">
                                <span class="badge bg-light text-dark">@(section.SectionName)</span>
                            </div>

                            @if (q.QuestionFormat == "Interest")
                            {
                                <p class="question-prompt mb-1">How much would you enjoy this?</p>
                            }

                            <h4 class="question-text mb-4">@q.Text</h4>

                            <div class="likert-scale">
                                @if (q.QuestionFormat == "Interest")
                                {
                                    string[] interestLabels = { "Strongly Dislike", "Dislike", "Neutral", "Like", "Strongly Like" };
                                    for (int v = 1; v <= 5; v++)
                                    {
                                        <button type="button"
                                                class="btn likert-btn @(q.CurrentAnswer == v ? "active" : "")"
                                                data-value="@v">
                                            <span class="likert-number">@v</span>
                                            <span class="likert-label">@interestLabels[v - 1]</span>
                                        </button>
                                    }
                                }
                                else
                                {
                                    string[] likertLabels = { "Strongly Disagree", "Disagree", "Neutral", "Agree", "Strongly Agree" };
                                    for (int v = 1; v <= 5; v++)
                                    {
                                        <button type="button"
                                                class="btn likert-btn @(q.CurrentAnswer == v ? "active" : "")"
                                                data-value="@v">
                                            <span class="likert-number">@v</span>
                                            <span class="likert-label">@likertLabels[v - 1]</span>
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                        globalIndex++;
                    }
                }

                <!-- Navigation -->
                <div class="quiz-nav d-flex justify-content-between mt-4">
                    <button id="btnPrev" class="btn btn-outline-secondary" disabled>
                        &larr; Previous
                    </button>
                    <button id="btnNext" class="btn btn-primary">
                        Next &rarr;
                    </button>
                    <form asp-action="Complete" method="post" id="completeForm" style="display:none;">
                        <button type="submit" id="btnComplete" class="btn btn-success btn-lg px-5">
                            See My Results
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

<input type="hidden" id="totalQuestions" value="@Model.TotalQuestions" />

@section Scripts {
    <script src="~/js/quiz.js" asp-append-version="true"></script>
}
